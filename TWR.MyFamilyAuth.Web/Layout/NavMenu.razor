@inject IAuthService AuthService
@inject NavigationManager Navigation
@using Microsoft.AspNetCore.Components.Authorization

@implements IDisposable

<nav class="navbar navbar-expand-md navbar-dark bg-dark px-3">
    <a class="navbar-brand fw-bold" href="/">
        <i class="bi bi-people-fill me-1"></i>MyFamilyAuth
    </a>

    <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
            data-bs-target="#navContent" aria-controls="navContent"
            aria-expanded="false" aria-label="Toggle navigation">
        <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navContent">
        <AuthorizeView>
            <Authorized>
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <NavLink class="nav-link" href="/" Match="NavLinkMatch.All">
                            <i class="bi bi-house me-1"></i>Dashboard
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link" href="/profile">
                            <i class="bi bi-person-circle me-1"></i>Profile
                        </NavLink>
                    </li>
                    <AuthorizeView Roles="SuperAdmin,FamilyAdmin" Context="adminCtx">
                        <Authorized>
                            <li class="nav-item">
                                <span class="nav-link text-secondary small text-uppercase" style="cursor:default;opacity:.6">Admin</span>
                            </li>
                            <li class="nav-item">
                                <NavLink class="nav-link" href="/admin/users">
                                    <i class="bi bi-people me-1"></i>Users
                                </NavLink>
                            </li>
                            <li class="nav-item">
                                <NavLink class="nav-link" href="/admin/groups">
                                    <i class="bi bi-diagram-3 me-1"></i>Groups
                                </NavLink>
                            </li>
                            <li class="nav-item">
                                <NavLink class="nav-link" href="/admin/apps">
                                    <i class="bi bi-grid-3x3-gap me-1"></i>Apps
                                </NavLink>
                            </li>
                            <li class="nav-item">
                                <NavLink class="nav-link" href="/admin/app-access">
                                    <i class="bi bi-shield-lock me-1"></i>App Access
                                </NavLink>
                            </li>
                        </Authorized>
                    </AuthorizeView>
                </ul>
                <div class="d-flex align-items-center gap-3 ms-auto">
                    <span class="navbar-text text-light small">@context.User.Identity?.Name</span>
                    <a class="btn btn-outline-light btn-sm" href="@HelpUrl">
                        <i class="bi bi-question-circle me-1"></i>Help
                    </a>
                    <button class="btn btn-outline-light btn-sm" @onclick="SignOut">Sign Out</button>
                </div>
            </Authorized>
        </AuthorizeView>
    </div>
</nav>

@code {
    private static readonly Dictionary<string, string> _sectionMap = new()
    {
        { "",                  "" },
        { "profile",           "my-profile" },
        { "admin/users",       "admin--users" },
        { "admin/groups",      "admin--groups" },
        { "admin/apps",        "admin--apps" },
        { "admin/app-access",  "admin--app-access" },
    };

    private string HelpUrl
    {
        get
        {
            var path = new Uri(Navigation.Uri).AbsolutePath.TrimStart('/').TrimEnd('/');
            return _sectionMap.TryGetValue(path, out var section) && !string.IsNullOrEmpty(section)
                ? $"/help/{section}"
                : "/help";
        }
    }

    protected override void OnInitialized()
    {
        Navigation.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        StateHasChanged();
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= OnLocationChanged;
    }

    private async Task SignOut()
    {
        await AuthService.LogoutAsync();
        Navigation.NavigateTo("/login");
    }
}
