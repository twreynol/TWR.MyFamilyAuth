@page "/login"
@layout LoginLayout
@attribute [AllowAnonymous]
@inject IAuthService AuthService
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>Sign In — MyFamilyAuth</PageTitle>

<div class="card shadow" style="width:400px">
    <div class="card-body p-4">
        <h4 class="card-title text-center mb-4">
            <i class="bi bi-people-fill text-primary me-2"></i>MyFamilyAuth
        </h4>

        @if (!string.IsNullOrEmpty(_error))
        {
            <div class="alert alert-danger py-2">@_error</div>
        }

        <div class="mb-3">
            <label class="form-label">Email</label>
            <input type="email" class="form-control" @bind="_email" @bind:event="oninput" placeholder="you@example.com" />
        </div>
        <div class="mb-3">
            <label class="form-label">Password</label>
            <input type="password" class="form-control" @bind="_password" @bind:event="oninput" @onkeydown="OnKeyDown" />
        </div>
        <div class="text-end mb-2">
            <a href="/forgot-password" class="small text-decoration-none">Forgot password?</a>
        </div>
        <div class="mb-4 form-check">
            <input class="form-check-input" type="checkbox" id="rememberMe" @bind="_rememberMe" />
            <label class="form-check-label" for="rememberMe">Remember me</label>
        </div>
        <button class="btn btn-primary w-100" @onclick="DoLogin" disabled="@_loading">
            @if (_loading)
            {
                <span class="spinner-border spinner-border-sm me-2"></span>
            }
            Sign In
        </button>
    </div>
</div>

@code {
    private string _email     = string.Empty;
    private string _password  = string.Empty;
    private string _error     = string.Empty;
    private bool   _loading;
    private bool   _rememberMe;

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await DoLogin();
    }

    private async Task DoLogin()
    {
        if (string.IsNullOrWhiteSpace(_email) || string.IsNullOrWhiteSpace(_password))
        {
            _error = "Email and password are required.";
            return;
        }
        _loading = true;
        _error   = string.Empty;
        var deviceTrust = await JS.InvokeAsync<string?>("localStorage.getItem", "device_trust_myfamilyauth");
        var ok = await AuthService.LoginAsync(new LoginRequest(_email, _password,
            AppClientId: "myfamilyauth",
            DeviceTrustToken: deviceTrust,
            RememberMe: _rememberMe));
        if (ok)
            Navigation.NavigateTo("/");
        else if (AuthService.PendingChallengeToken != null)
            Navigation.NavigateTo("/login/verify-2fa");
        else
            _error = AuthService.LastLoginError ?? "Invalid email or password.";
        _loading = false;
    }
}
