@page "/login"
@layout LoginLayout
@attribute [AllowAnonymous]
@inject BuildInfoService BuildInfo

<PageTitle>Sign In — MyFamilyAuth</PageTitle>

<div class="twr-login-card card shadow-lg">
    <div class="card-body p-5">
        <div class="text-center mb-4">
            <img src="images/icon.svg" alt="MyFamilyAuth"
                 style="width:148px;height:148px;object-fit:contain;border-radius:28px;
                        box-shadow:0 6px 24px rgba(var(--twr-login-icon-shadow-rgb),0.28);" />
            <h3 class="mt-3 mb-1 fw-bold twr-login-title">
                MyFamily<span class="twr-login-accent">Auth</span>
            </h3>
            <p class="twr-login-tagline">One secure sign-in for the whole family.</p>
        </div>

        <hr class="twr-login-divider mb-4" />

        <LoginForm AppDisplayName="MyFamilyAuth" MustChangePasswordRedirectUrl="/profile?mustchange=1" />

        @if (_version is not null)
        {
            <p class="text-center text-muted mt-3 mb-0" style="font-size:0.7rem;opacity:0.6">
                v@_version
            </p>
        }
    </div>
</div>


@code {
    private string? _version;

    protected override async Task OnInitializedAsync()
    {
        _version = await BuildInfo.GetVersionAsync();
        if (_version == "dev") _version = null;
    }
}
