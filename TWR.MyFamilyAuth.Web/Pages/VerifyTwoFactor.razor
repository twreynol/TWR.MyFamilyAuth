@page "/login/verify-2fa"
@layout LoginLayout
@attribute [AllowAnonymous]
@inject IAuthService AuthService
@inject NavigationManager Navigation

<PageTitle>Verify Identity — MyFamilyAuth</PageTitle>

<div class="card shadow" style="width:400px">
    <div class="card-body p-4">
        <h4 class="card-title text-center mb-2">
            <i class="bi bi-shield-check text-primary me-2"></i>Verify Your Identity
        </h4>
        <p class="text-center text-muted small mb-4">A 6-digit code was sent to your email address.</p>

        @if (!string.IsNullOrEmpty(_error))
        {
            <div class="alert alert-danger py-2">@_error</div>
        }

        <div class="mb-3">
            <label class="form-label">Verification Code</label>
            <input type="text" class="form-control text-center fs-4 letter-spacing-3"
                   maxlength="6"
                   @bind="_code"
                   @bind:event="oninput"
                   @ref="_codeInput"
                   placeholder="------" />
        </div>

        <div class="mb-4 form-check">
            <input class="form-check-input" type="checkbox" id="trustDevice" @bind="_trustDevice" />
            <label class="form-check-label" for="trustDevice">Trust this device for 90 days</label>
        </div>

        <button class="btn btn-primary w-100" @onclick="DoVerify"
                disabled="@(_loading || _code.Length != 6)">
            @if (_loading)
            {
                <span class="spinner-border spinner-border-sm me-2"></span>
            }
            Verify
        </button>

        <div class="text-center mt-3">
            <a href="/login" class="small text-decoration-none">Back to sign in</a>
        </div>
    </div>
</div>

@code {
    private string   _code        = string.Empty;
    private bool     _trustDevice;
    private bool     _loading;
    private string   _error       = string.Empty;
    private ElementReference _codeInput;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            if (AuthService.PendingChallengeToken is null)
            {
                Navigation.NavigateTo("/login");
                return;
            }
            try { await _codeInput.FocusAsync(); } catch { /* ignore */ }
        }
    }

    private async Task DoVerify()
    {
        if (_code.Length != 6) return;
        _loading = true;
        _error   = string.Empty;
        var ok   = await AuthService.VerifyTwoFactorAsync(_code, _trustDevice);
        if (ok)
            Navigation.NavigateTo("/");
        else
            _error = AuthService.LastLoginError ?? "Invalid or expired verification code.";
        _loading = false;
    }
}
