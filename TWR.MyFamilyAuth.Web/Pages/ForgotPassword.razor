@page "/forgot-password"
@layout LoginLayout
@attribute [AllowAnonymous]
@inject IAuthService AuthService
@inject NavigationManager Navigation

<PageTitle>Reset Password — MyFamilyAuth</PageTitle>

<div class="card shadow" style="width:400px">
    <div class="card-body p-4">
        <h4 class="card-title text-center mb-4">
            <i class="bi bi-key-fill text-primary me-2"></i>Reset Password
        </h4>

        @if (!string.IsNullOrEmpty(_error))
        {
            <div class="alert alert-danger py-2">@_error</div>
        }

        @if (_success)
        {
            <div class="alert alert-success py-2">
                Your password has been reset successfully.
            </div>
            <div class="text-center mt-3">
                <a href="/login" class="btn btn-outline-primary btn-sm">Back to sign in</a>
            </div>
        }
        else if (_step == 1)
        {
            <div class="mb-3">
                <label class="form-label">Email</label>
                <input type="email" class="form-control" @bind="_email" @bind:event="oninput"
                       placeholder="you@example.com" />
            </div>
            <button class="btn btn-primary w-100 mb-3" @onclick="SendCode" disabled="@_loading">
                @if (_loading)
                {
                    <span class="spinner-border spinner-border-sm me-2"></span>
                }
                Send Reset Code
            </button>
            <div class="text-center">
                <a href="/login" class="small text-decoration-none">Back to sign in</a>
            </div>
        }
        else
        {
            <p class="text-muted small mb-3">A 6-digit code was sent to <strong>@_email</strong>.</p>
            <div class="mb-3">
                <label class="form-label">Code</label>
                <input type="text" class="form-control" maxlength="6" @bind="_code" @bind:event="oninput"
                       placeholder="123456" />
            </div>
            <div class="mb-3">
                <label class="form-label">New Password</label>
                <input type="password" class="form-control" @bind="_newPassword" @bind:event="oninput" />
            </div>
            <div class="mb-4">
                <label class="form-label">Confirm New Password</label>
                <input type="password" class="form-control" @bind="_confirmPassword" @bind:event="oninput" />
            </div>
            <button class="btn btn-primary w-100 mb-3" @onclick="DoReset" disabled="@_loading">
                @if (_loading)
                {
                    <span class="spinner-border spinner-border-sm me-2"></span>
                }
                Reset Password
            </button>
            <div class="text-center">
                <a href="/login" class="small text-decoration-none">Back to sign in</a>
            </div>
        }
    </div>
</div>

@code {
    private int    _step            = 1;
    private string _email           = string.Empty;
    private string _code            = string.Empty;
    private string _newPassword     = string.Empty;
    private string _confirmPassword = string.Empty;
    private string _error           = string.Empty;
    private bool   _loading;
    private bool   _success;

    private async Task SendCode()
    {
        if (string.IsNullOrWhiteSpace(_email))
        {
            _error = "Email is required.";
            return;
        }
        _loading = true;
        _error   = string.Empty;
        var ok   = await AuthService.ForgotPasswordAsync(_email.Trim());
        _loading = false;
        if (ok)
            _step = 2;
        else
            _error = AuthService.LastLoginError ?? "Failed to send reset code.";
    }

    private async Task DoReset()
    {
        if (string.IsNullOrWhiteSpace(_code))
        {
            _error = "Please enter the 6-digit code.";
            return;
        }
        if (_newPassword.Length < 8)
        {
            _error = "Password must be at least 8 characters.";
            return;
        }
        if (_newPassword != _confirmPassword)
        {
            _error = "Passwords do not match.";
            return;
        }
        _loading = true;
        _error   = string.Empty;
        var ok   = await AuthService.ResetPasswordAsync(_code.Trim(), _newPassword);
        _loading = false;
        if (ok)
            _success = true;
        else
            _error = AuthService.LastLoginError ?? "Invalid or expired reset code.";
    }
}
