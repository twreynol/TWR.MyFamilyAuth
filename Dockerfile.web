FROM mcr.microsoft.com/dotnet/sdk:10.0 AS build
WORKDIR /src

# TWR.Shared.Components is consumed as a NuGet package from GitHub Packages via
# nuget.config — no sibling repo checkout needed. GH_PACKAGES_TOKEN is passed as a
# build-arg and substituted into nuget.config's %GH_PACKAGES_TOKEN% placeholder.
ARG GH_PACKAGES_TOKEN
ENV GH_PACKAGES_TOKEN=$GH_PACKAGES_TOKEN

COPY nuget.config ./
COPY TWR.MyFamilyAuth.Contracts/TWR.MyFamilyAuth.Contracts.csproj TWR.MyFamilyAuth.Contracts/
COPY TWR.MyFamilyAuth.Web/TWR.MyFamilyAuth.Web.csproj             TWR.MyFamilyAuth.Web/
RUN dotnet restore TWR.MyFamilyAuth.Web/TWR.MyFamilyAuth.Web.csproj

# Copy source
COPY TWR.MyFamilyAuth.Contracts/ TWR.MyFamilyAuth.Contracts/
COPY TWR.MyFamilyAuth.Web/       TWR.MyFamilyAuth.Web/

RUN dotnet publish TWR.MyFamilyAuth.Web/TWR.MyFamilyAuth.Web.csproj \
    -c Release -o /app

# APPSETTINGS_FILE selects the environment config baked into the image.
# docker-compose passes "appsettings.Docker.json"; fly.io passes "appsettings.ProductionV2.json"
ARG APPSETTINGS_FILE=appsettings.Docker.json
RUN cp TWR.MyFamilyAuth.Web/wwwroot/${APPSETTINGS_FILE} \
       /app/wwwroot/appsettings.json && \
    cp TWR.MyFamilyAuth.Web/wwwroot/${APPSETTINGS_FILE} \
       /app/wwwroot/appsettings.Production.json

# Bake the version into a static JSON file the Blazor app can fetch.
ARG BUILD_VERSION=dev
RUN echo "{\"version\":\"$BUILD_VERSION\"}" > /app/wwwroot/buildinfo.json

# .NET 10 fingerprints framework assets (e.g. blazor.webassembly.abc123.js)
# but index.html still references the plain name. nginx doesn't know the mapping,
# so we copy each fingerprinted file to its plain-name equivalent.
RUN for f in /app/wwwroot/_framework/blazor.webassembly.*.js; do \
      [ -f "$f" ] && cp "$f" /app/wwwroot/_framework/blazor.webassembly.js; \
    done; \
    for f in /app/wwwroot/_framework/dotnet.*.js; do \
      plain=$(echo "$f" | sed 's/\.[a-z0-9]\{10\}\.js$/.js/'); \
      [ -f "$f" ] && cp "$f" "$plain"; \
    done

FROM nginx:alpine
COPY --from=build /app/wwwroot /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
